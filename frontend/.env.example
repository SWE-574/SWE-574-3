# ─── API ─────────────────────────────────────────────────────────────────────
# Base URL for the backend API.
# In development the Vite proxy rewrites /api → http://localhost:8000, so leave this as-is.
VITE_API_URL=/api

# ─── Mapbox ──────────────────────────────────────────────────────────────────
# Required for the interactive map (MapView component).
# Obtain a token at https://account.mapbox.com/access-tokens/
#
# ⚠️  Restrict the token to your production domain in the Mapbox dashboard
#     to prevent unauthorised usage / unexpected billing.
#
# Free tier: 50,000 map loads/month — sufficient for development & demo.
VITE_MAPBOX_TOKEN=pk.eyJ1IjoiWU9VUl9VU0VSTkFNRSIsImEiOiJZT1VSX1RPS0VOX0hFUkUifQ.XXXXX
