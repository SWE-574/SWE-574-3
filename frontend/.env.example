# ─── Frontend env vars ────────────────────────────────────────────────────────
# Vite is configured (envDir in vite.config.ts) to read VITE_* vars from the
# ROOT .env file (../.env). You do NOT need a separate frontend/.env file.
#
# If you still want a local override, create frontend/.env with these vars:
#
# VITE_API_URL=/api
# VITE_MAPBOX_TOKEN=pk.eyJ1IjoiWU9VUl9VU0VSTkFNRSIsImEiOiJZT1VSX1RPS0VOX0hFUkUifQ.XXXXX
